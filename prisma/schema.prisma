generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id    String  @id @default(cuid())
  title String?
  body  String?
}

model User {
  id String @id @default(cuid())
  userName String
  email String
  phoneNumber String?

}